generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id                String   @id @default(uuid())
  asin              String
  title             String
  acquisitionType   String   @default("SAMPLE")
  dispositionType   String   @default("KEPT")
  videoDone         Boolean  @default(true)
  videoDoneAt       DateTime?
  videoSlaDays      Int      @default(14)
  videoNotes        String?
  receivedDate      DateTime
  receiptValueCents Int
  currency          String   @default("USD")
  soldDate          DateTime?
  saleProceedsCents Int?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([asin])
  @@index([asin, receivedDate])
  @@index([receivedDate])
  @@index([soldDate])
}
